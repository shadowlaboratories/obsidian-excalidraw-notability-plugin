{
  "compilerOptions": {
    "baseUrl": ".",
    "sourceMap": false,
    "module": "es2020",
    "target": "es2022", //min es2017 because script engine requires for async execution and min es2018 for named capture groups
    "allowJs": false,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "importHelpers": true,
    "resolveJsonModule": true,
    "paths": {
      "@zsviczian/excalidraw/types/excalidraw/types": [
        "src/types/excalidraw-app-types-compat.d.ts"
      ],
      "@zsviczian/excalidraw/types/element/src/types": [
        "src/types/excalidraw-element-types-compat.d.ts"
      ],
      "@zsviczian/excalidraw": [
        "dist/excalidraw-notability-types/excalidraw/index.d.ts"
      ],
      "@zsviczian/excalidraw/types/excalidraw/*": [
        "dist/excalidraw-notability-types/excalidraw/*"
      ],
      "@zsviczian/excalidraw/types/common/*": [
        "dist/excalidraw-notability-types/common/*"
      ],
      "@zsviczian/excalidraw/types/element/*": [
        "dist/excalidraw-notability-types/element/*"
      ],
      "@zsviczian/excalidraw/types/math/*": [
        "dist/excalidraw-notability-types/math/*"
      ],
      "@zsviczian/excalidraw/types/utils/*": [
        "dist/excalidraw-notability-types/utils/*"
      ],
      "@excalidraw/common": [
        "dist/excalidraw-notability-types/common/src/index.d.ts"
      ],
      "@excalidraw/common/*": [
        "dist/excalidraw-notability-types/common/src/*"
      ],
      "@excalidraw/element": [
        "dist/excalidraw-notability-types/element/src/index.d.ts"
      ],
      "@excalidraw/element/*": [
        "dist/excalidraw-notability-types/element/src/*"
      ],
      "@excalidraw/math": [
        "dist/excalidraw-notability-types/math/src/index.d.ts"
      ],
      "@excalidraw/math/*": [
        "dist/excalidraw-notability-types/math/src/*"
      ],
      "@excalidraw/utils": [
        "dist/excalidraw-notability-types/utils/src/index.d.ts"
      ],
      "@excalidraw/utils/*": [
        "dist/excalidraw-notability-types/utils/src/*"
      ]
    },
    "lib": [
      "dom",
      "scripthost",
      "es2022",
      "DOM.Iterable"
    ],
    "jsx": "react",
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/types/**/*.d.ts"
  ]
}
